alias act='act --container-architecture linux/amd64 --github-instance=github.sie.sony.com'
alias gitb='git branch'
alias gitco='git checkout'
alias gitdh='git diff HEAD'
alias gitfu='git fetch upstream ; git rebase upstream/master'
alias gitp='git pull'
alias gitpu='git push --set-upstream origin $(git branch --show-current)'
alias gits='git status'
